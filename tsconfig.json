{
	"compilerOptions": {
	  "target": "ESNext",
	  "useDefineForClassFields": true,
	  "module": "ESNext",
	  "moduleResolution": "bundler",
	  "strict": true,
	  "jsx": "preserve",
	  "resolveJsonModule": true,
	  "isolatedModules": true,
	  "esModuleInterop": true,
	  "lib": ["ESNext", "DOM"],
	  "skipLibCheck": true,
	  "noEmit": true,
	  "baseUrl": "./",
	  "paths": {
		"@": ["src"],
		"@/*": ["src/*"]
	  },
	  "typeRoots": ["./node_modules/@types", "./src/types"],
	  "types": ["node", "deep-diff"]
	},
	"include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.tsx", "src/**/*.vue", "utils/http.js"],
	"references": [{ "path": "./tsconfig.node.json" }]
  }